# neo-research-briefs environment configuration
#
# Copy to `.env` and fill in the values you actually use.
# All integrations are optional individually; you only need the ones you have enabled.

# --- Watcher behavior ---------------------------------------------------------
# Identifier stamped into the source when this watcher claims a brief.
NEO_BRIEFS_CLAIMER=openclaw:research-briefs
# Dry run prints planned actions without writing to external systems.
NEO_BRIEFS_DRY_RUN=true
# Comma-separated list of adapters to enable: notion,discord,github,obsidian
NEO_BRIEFS_ENABLED_ADAPTERS=obsidian
# Max briefs claimed per run. Keeps a misconfigured run from stampeding.
NEO_BRIEFS_MAX_PER_RUN=3

# --- Notion -------------------------------------------------------------------
# Internal integration secret from https://notion.so/my-integrations
NOTION_TOKEN=
# The database ID (not the page ID) of the Research Briefs database.
NOTION_DATABASE_ID=
NOTION_API_BASE=https://api.notion.com/v1
NOTION_VERSION=2022-06-28
NOTION_STATUS_PROPERTY=Status
NOTION_WANT_VALUE=Want
NOTION_IMPLEMENTING_VALUE=Implementing
NOTION_TITLE_PROPERTY=Name
NOTION_SUMMARY_PROPERTY=Summary
NOTION_WHY_IT_MATTERS_PROPERTY=Why it matters
NOTION_SOURCE_URL_PROPERTY=Source URL
NOTION_TARGET_REPO_PROPERTY=Target Repo
NOTION_DISCORD_THREAD_URL_PROPERTY=Discord Thread URL
NOTION_GITHUB_ISSUE_URL_PROPERTY=GitHub Issue URL
NOTION_GITHUB_PR_URL_PROPERTY=GitHub PR URL
NOTION_CLAIMED_BY_PROPERTY=Claimed By
NOTION_CLAIMED_AT_PROPERTY=Claimed At
NOTION_LAST_SYNC_AT_PROPERTY=Last Sync At
NOTION_ERROR_PROPERTY=Error

# --- Discord ------------------------------------------------------------------
# Bot token for the account that will create implementation threads.
DISCORD_BOT_TOKEN=
# Channel ID (not name) of the intake channel, e.g. #implement-research.
DISCORD_INTAKE_CHANNEL_ID=
DISCORD_API_BASE=https://discord.com/api/v10
# Discord accepts 60, 1440, 4320, or 10080.
DISCORD_AUTO_ARCHIVE_DURATION=1440
# How many recent thread messages to inspect before posting the starter message.
DISCORD_STARTER_MESSAGE_HISTORY_LIMIT=10

# --- GitHub -------------------------------------------------------------------
# Prefer relying on `gh auth login` on the host. Token is a fallback.
GITHUB_TOKEN=
# Default repo for briefs that do not specify one, owner/name form.
GITHUB_DEFAULT_REPO=
GITHUB_API_BASE=https://api.github.com
GITHUB_PREFER_GH_CLI=true

# --- Obsidian -----------------------------------------------------------------
# Absolute path to the vault. Example: /path/to/Obsidian/Research
OBSIDIAN_VAULT_PATH=
# Folder inside the vault that holds research briefs.
OBSIDIAN_BRIEFS_FOLDER=Research Briefs
# Frontmatter field used as the workflow status.
OBSIDIAN_STATUS_FIELD=status
OBSIDIAN_WANT_VALUE=want
