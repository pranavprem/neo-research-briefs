# neo-research-briefs environment configuration
#
# Copy to `.env` and fill in the values you actually use.
# All integrations are optional individually; you only need the ones you have enabled.

# --- Watcher behavior ---------------------------------------------------------
# Identifier stamped into Notion's "Claimed By" when this watcher claims a brief.
NEO_BRIEFS_CLAIMER=openclaw:research-briefs
# Dry run prints the actions the watcher would take without writing to external systems.
NEO_BRIEFS_DRY_RUN=true
# Comma-separated list of adapters to enable: notion,discord,github,obsidian
NEO_BRIEFS_ENABLED_ADAPTERS=obsidian
# Max briefs claimed per run. Keeps a misconfigured run from stampeding.
NEO_BRIEFS_MAX_PER_RUN=3

# --- Notion -------------------------------------------------------------------
# Internal integration secret from https://www.notion.so/my-integrations
NOTION_TOKEN=
# The database ID (not the page ID) of the Research Briefs database.
NOTION_DATABASE_ID=
# Optional: override the property name the watcher watches.
NOTION_STATUS_PROPERTY=Status
NOTION_WANT_VALUE=Want

# --- Discord ------------------------------------------------------------------
# Bot token for the account that will create implementation threads.
DISCORD_BOT_TOKEN=
# Channel ID (not name) of the intake channel, e.g. #implement-research.
DISCORD_INTAKE_CHANNEL_ID=

# --- GitHub -------------------------------------------------------------------
# Prefer relying on `gh auth login` on the host. Token is a fallback.
GITHUB_TOKEN=
# Default repo for briefs that do not specify one, owner/name form.
GITHUB_DEFAULT_REPO=

# --- Obsidian -----------------------------------------------------------------
# Absolute path to the vault. Example: /Users/you/Obsidian/Research
OBSIDIAN_VAULT_PATH=
# Folder inside the vault that holds research briefs.
OBSIDIAN_BRIEFS_FOLDER=Research Briefs
# Frontmatter field used as the workflow status.
OBSIDIAN_STATUS_FIELD=status
OBSIDIAN_WANT_VALUE=want
